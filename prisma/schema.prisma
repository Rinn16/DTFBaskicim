generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==================== ENUMS ====================

enum UserRole {
  CUSTOMER
  ADMIN
}

enum AuthProvider {
  EMAIL
  PHONE
  GOOGLE
}

enum OrderStatus {
  PENDING_PAYMENT
  PROCESSING
  SHIPPED
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  CREDIT_CARD
  BANK_TRANSFER
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum BillingType {
  INDIVIDUAL
  CORPORATE
}

enum InvoiceType {
  SATIS
  IADE
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  CANCELLED
  SENT_TO_GIB
  ACCEPTED
  REJECTED
}

enum TransactionType {
  PAYMENT
  REFUND
  PARTIAL_REFUND
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
}

// ==================== USER & AUTH ====================

model User {
  id            String       @id @default(cuid())
  email         String?      @unique
  phone         String?      @unique
  passwordHash  String?
  name          String
  surname       String
  companyName   String?
  taxNumber     String?
  authProvider  AuthProvider
  role          UserRole     @default(CUSTOMER)
  emailVerified Boolean      @default(false)
  phoneVerified Boolean      @default(false)
  image         String?

  billingType        BillingType @default(INDIVIDUAL)
  billingFirstName   String?
  billingLastName    String?
  billingFullName    String?
  billingCompanyName String?
  billingTaxOffice   String?
  billingTaxNumber   String?
  billingAddress     String?     @db.Text
  billingCity        String?
  billingDistrict    String?
  billingZipCode     String?

  sessionsInvalidatedAt DateTime?
  emailOptIn            Boolean  @default(true)
  smsOptIn              Boolean  @default(true)
  pendingEmail          String?  // Email change: address awaiting verification
  pendingPhone          String?  // Phone change: number awaiting OTP verification

  addresses      Address[]
  orders         Order[]
  cartItems      CartItem[]
  designDrafts   DesignDraft[]
  specialPricing CustomerPricing?
  accounts       Account[]
  sessions       Session[]
  userSessions   UserSession[]
  discountUsages DiscountUsage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([phone])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserSession {
  id        String   @id @default(cuid())
  userId    String
  userAgent String?
  ipAddress String?
  createdAt DateTime @default(now())
  lastSeenAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@index([identifier])
}

model OtpCode {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  verified  Boolean  @default(false)
  attempts  Int      @default(0)

  createdAt DateTime @default(now())

  @@index([phone, code])
  @@index([expiresAt])
}

// ==================== ADDRESS ====================

model Address {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  fullName  String
  phone     String
  city      String
  district  String
  address   String  @db.Text
  zipCode   String?
  isDefault Boolean @default(false)

  orders Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ==================== PRICING ====================

model PricingTier {
  id            String   @id @default(cuid())
  minMeters     Decimal  @db.Decimal(10, 2)
  maxMeters     Decimal? @db.Decimal(10, 2)
  pricePerMeter Decimal  @db.Decimal(10, 2)
  isActive      Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model CustomerPricing {
  id            String  @id @default(cuid())
  userId        String  @unique
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  pricePerMeter Decimal @db.Decimal(10, 2)
  notes         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DiscountCode {
  id              String   @id @default(cuid())
  code            String   @unique
  discountPercent Decimal? @db.Decimal(5, 2)
  discountAmount  Decimal? @db.Decimal(10, 2)
  minOrderMeters  Decimal? @db.Decimal(10, 2)
  maxUses         Int?
  usedCount       Int      @default(0)
  validFrom       DateTime
  validUntil      DateTime
  isActive        Boolean  @default(true)

  orders Order[]
  usages DiscountUsage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([isActive])
}

model DiscountUsage {
  id             String       @id @default(cuid())
  userId         String
  discountCodeId String
  orderId        String       @unique

  user         User         @relation(fields: [userId], references: [id])
  discountCode DiscountCode @relation(fields: [discountCodeId], references: [id])
  order        Order        @relation(fields: [orderId], references: [id])

  usedAt DateTime @default(now())

  @@unique([userId, discountCodeId])
  @@index([discountCodeId])
}

model ShippingConfig {
  id              String   @id @default("default")
  shippingCost    Decimal  @db.Decimal(10, 2) @default(49.90)
  freeShippingMin Decimal  @db.Decimal(10, 2) @default(500)
  isActive        Boolean  @default(true)
  updatedAt       DateTime @updatedAt
}

model SiteSettings {
  id                String   @id @default("default")
  smsEnabled        Boolean  @default(false)
  emailEnabled      Boolean  @default(false)
  emailWelcome      Boolean  @default(true)
  emailOrderConfirm Boolean  @default(true)
  emailShipped      Boolean  @default(true)
  emailAdminNewOrder Boolean  @default(true)

  // Fatura firma bilgileri (DTF Baskıcım'dan farklı olabilir)
  invoiceCompanyName      String?
  invoiceCompanyTaxNumber String?
  invoiceCompanyTaxOffice String?
  invoiceCompanyAddress   String?  @db.Text
  invoiceCompanyCity      String?
  invoiceCompanyDistrict  String?
  invoiceCompanyZipCode   String?
  invoiceCompanyPhone     String?
  invoiceCompanyEmail     String?
  invoiceCompanyIban      String?
  invoiceCompanyWebsite   String?
  invoiceCompanyLogoKey   String?
  invoiceNotes            String?  @db.Text

  // Fatura numaralama
  invoicePrefix     String  @default("DTF-F")
  invoiceNextNumber Int     @default(1)

  // E-fatura ayarları (Trendyol E-Faturam)
  efaturaEnabled       Boolean @default(false)
  efaturaEnvironment   String  @default("test") // "test" veya "production"
  efaturaEmail         String?
  efaturaPassword      String?
  efaturaEarsivPrefix  String  @default("DAP") // E-Arşiv seri ön eki (3 harf)
  efaturaEfaturaPrefix String  @default("DIP") // E-Fatura seri ön eki (3 harf)

  // Üretim duraklatma
  ordersPaused        Boolean @default(false)
  ordersPausedMessage String? @db.Text

  updatedAt DateTime @updatedAt
}

// ==================== ORDERS ====================

model Order {
  id          String  @id @default(cuid())
  orderNumber String  @unique
  userId      String?
  user        User?   @relation(fields: [userId], references: [id])

  addressId String?
  address   Address? @relation(fields: [addressId], references: [id])

  // Misafir checkout alanlari
  guestEmail String?
  guestName  String?
  guestPhone String?

  totalMeters    Decimal @db.Decimal(10, 4)
  pricePerMeter  Decimal @db.Decimal(10, 2)
  subtotal       Decimal @db.Decimal(10, 2)
  discountAmount Decimal @db.Decimal(10, 2) @default(0)
  taxAmount      Decimal @db.Decimal(10, 2)
  totalAmount    Decimal @db.Decimal(10, 2)
  shippingCost   Decimal @db.Decimal(10, 2) @default(0)

  discountCodeId String?
  discountCode   DiscountCode? @relation(fields: [discountCodeId], references: [id])

  status OrderStatus @default(PENDING_PAYMENT)

  paymentMethod PaymentMethod
  paymentStatus PaymentStatus @default(PENDING)
  paymentId     String?

  gangSheetLayout Json
  gangSheetWidth  Int
  gangSheetHeight Int

  exportPng  String?
  exportTiff String?
  exportPdf  String?

  trackingCode String?

  customerNote    String?   @db.Text
  adminNote       String?   @db.Text
  termsAcceptedAt DateTime?

  billingType        BillingType @default(INDIVIDUAL)
  billingSameAddress Boolean     @default(true)
  billingFirstName   String?
  billingLastName    String?
  billingFullName    String?
  billingCompanyName String?
  billingTaxOffice   String?
  billingTaxNumber   String?
  billingAddress     String?     @db.Text
  billingCity        String?
  billingDistrict    String?
  billingZipCode     String?

  items         OrderItem[]
  statusHistory OrderStatusHistory[]
  gangSheets    OrderGangSheet[]
  invoices      Invoice[]
  transactions  PaymentTransaction[]
  discountUsage DiscountUsage?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([orderNumber])
  @@index([createdAt])
}

model OrderItem {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  imageKey    String
  imageName   String
  imageWidth  Int
  imageHeight Int

  quantity   Int  @default(1)
  placements Json

  createdAt DateTime @default(now())

  @@index([orderId])
}

model OrderStatusHistory {
  id         String       @id @default(cuid())
  orderId    String
  order      Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fromStatus OrderStatus?
  toStatus   OrderStatus
  changedBy  String?
  note       String?
  eventType  String?

  createdAt DateTime @default(now())

  @@index([orderId])
}

model OrderGangSheet {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  gangSheetLayout Json
  gangSheetWidth  Int
  gangSheetHeight Int
  totalMeters     Decimal @db.Decimal(10, 4)

  exportPng  String?
  exportTiff String?
  exportPdf  String?

  createdAt DateTime @default(now())

  @@index([orderId])
}

// ==================== DESIGN DRAFTS ====================

model DesignDraft {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String   @default("Adsız Tasarım")
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ==================== CART ====================

model CartItem {
  id          String  @id @default(cuid())
  userId      String
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  layout      Json
  totalMeters Decimal @db.Decimal(10, 4)
  items       Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ==================== EMAIL TEMPLATES ====================

enum EmailTemplateType {
  WELCOME
  ORDER_CONFIRMATION
  SHIPPED
}

model EmailTemplate {
  id        String            @id @default(cuid())
  name      String
  type      EmailTemplateType @unique
  subject   String
  content   String            @db.Text
  isActive  Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

// ==================== SMS ====================

enum SmsTemplateType {
  SIPARIS_ONAYLANDI
  KARGOYA_VERILDI
  KAMPANYA
}

model SmsTemplate {
  id        String          @id @default(cuid())
  name      String
  content   String          @db.Text
  type      SmsTemplateType
  isActive  Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model SmsLog {
  id             String   @id @default(cuid())
  templateId     String?
  message        String   @db.Text
  recipientCount Int
  successCount   Int      @default(0)
  failCount      Int      @default(0)
  sentBy         String
  createdAt      DateTime @default(now())

  @@index([createdAt])
}

// ==================== INVOICE & TRANSACTIONS ====================

model Invoice {
  id             String        @id @default(cuid())
  invoiceNumber  String        @unique
  orderId        String
  order          Order         @relation(fields: [orderId], references: [id])
  type           InvoiceType   @default(SATIS)
  status         InvoiceStatus @default(DRAFT)

  // Fatura anındaki satıcı firma bilgileri snapshot
  sellerName      String
  sellerTaxNumber String
  sellerTaxOffice String
  sellerAddress   String? @db.Text
  sellerCity      String?
  sellerPhone     String?

  // Alıcı bilgileri snapshot
  billingType        BillingType
  billingFirstName   String?
  billingLastName    String?
  billingFullName    String?
  billingCompanyName String?
  billingTaxOffice   String?
  billingTaxNumber   String?
  billingAddress     String? @db.Text
  billingCity        String?
  billingDistrict    String?
  billingZipCode     String?

  // Finansal snapshot
  subtotal       Decimal @db.Decimal(10, 2)
  discountAmount Decimal @db.Decimal(10, 2) @default(0)
  taxRate        Decimal @db.Decimal(5, 2)  @default(20)
  taxAmount      Decimal @db.Decimal(10, 2)
  totalAmount    Decimal @db.Decimal(10, 2)
  shippingCost   Decimal @db.Decimal(10, 2) @default(0)

  lineItems Json

  pdfKey String?

  // E-fatura alanları
  gibInvoiceId String?
  gibStatus    String?
  ublXmlKey    String?

  issuedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([orderId])
  @@index([invoiceNumber])
  @@index([status])
}

model PaymentTransaction {
  id       String            @id @default(cuid())
  orderId  String
  order    Order             @relation(fields: [orderId], references: [id])
  type     TransactionType
  status   TransactionStatus @default(PENDING)
  amount   Decimal           @db.Decimal(10, 2)
  currency String            @default("TRY")

  gatewayRef  String?
  gatewayData Json?

  refundReason String? @db.Text
  refundedBy   String?
  note         String? @db.Text

  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([type])
}
